generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth required models ─────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(BUYER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  breederProfile BreederProfile?
  favorites      Favorite[]
  sentMessages   Message[]      @relation("SentMessages")
  buyerConvos    Conversation[] @relation("BuyerConversations")
  reviews        Review[]
  reports        Report[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─── Marketplace models ───────────────────────────────────────────────────────

model BreederProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  bio         String?
  phone       String?
  city        String
  avgRating   Float    @default(0)
  reviewCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings      Listing[]
  reviews       Review[]
  breederConvos Conversation[] @relation("BreederConversations")
}

model Listing {
  id                String            @id @default(cuid())
  breederId         String
  title             String
  species           Species
  breed             String
  ageValue          Int
  ageUnit           AgeUnit
  gender            Gender
  price             Float?
  status            ListingStatus     @default(AVAILABLE)
  description       String
  vaccinationStatus VaccinationStatus @default(NONE)
  purpose           ListingPurpose    @default(SALE)
  city              String            @default("")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  breeder       BreederProfile  @relation(fields: [breederId], references: [id], onDelete: Cascade)
  images        ListingImage[]
  favorites     Favorite[]
  conversations Conversation[]
  reviews       Review[]
}

model ListingImage {
  id           String   @id @default(cuid())
  listingId    String
  url          String
  displayOrder Int      @default(0)
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

model Conversation {
  id         String   @id @default(cuid())
  listingId  String
  buyerId    String
  breederId  String
  createdAt  DateTime @default(now())
  lastMsgAt  DateTime @default(now())

  listing  Listing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer    User           @relation("BuyerConversations", fields: [buyerId], references: [id])
  breeder  BreederProfile @relation("BreederConversations", fields: [breederId], references: [id])
  messages Message[]

  @@unique([listingId, buyerId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime  @default(now())
  readAt         DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id])
}

model Review {
  id         String   @id @default(cuid())
  reviewerId String
  breederId  String
  listingId  String?
  rating     Int
  body       String?
  createdAt  DateTime @default(now())

  reviewer User           @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  breeder  BreederProfile @relation(fields: [breederId], references: [id], onDelete: Cascade)
  listing  Listing?       @relation(fields: [listingId], references: [id])

  @@unique([reviewerId, breederId])
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  targetType TargetType
  targetId   String
  reason     String
  status     ReportStatus @default(OPEN)
  adminNote  String?
  createdAt  DateTime     @default(now())

  reporter User @relation(fields: [reporterId], references: [id], onDelete: Cascade)
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  BUYER
  BREEDER
  ADMIN
}

enum Species {
  DOG
  CAT
  BIRD
  RABBIT
  FISH
  RODENT
  REPTILE
  EXOTIC
}

enum AgeUnit {
  WEEKS
  MONTHS
  YEARS
}

enum Gender {
  MALE
  FEMALE
}

enum ListingStatus {
  AVAILABLE
  ARCHIVED
}

enum ListingPurpose {
  SALE
  BREEDING
}

enum VaccinationStatus {
  NONE
  PARTIAL
  FULL
}

enum TargetType {
  LISTING
  BREEDER
  REVIEW
  MESSAGE
}

enum ReportStatus {
  OPEN
  REVIEWED
  DISMISSED
  ACTIONED
}
